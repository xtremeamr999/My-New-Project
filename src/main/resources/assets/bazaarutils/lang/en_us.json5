{
  "owo:extended_lang": true,

  "bazaarutils.ref.{}": {
    "instant_sell": [{
      "text": "Instant Sell",
      "color": "green"
    }],

    "booster_cookie": [{
      "text": "Booster Cookie",
      "color": "light_purple",
      "hover_event": {
        "action": "show_text",
        "value": [
          { "text": "Booster Cookie\n", "color": "light_purple", "bold": true },
          { "text": "Grants access to the Bazaar order API\nand other SkyBlock perks.\n\n", "color": "gray" },
          { "text": "↗ Click to open wiki", "color": "dark_gray", "italic": true }
        ]
      },
      "click_event": {
        "action": "open_url",
        "url": "https://wiki.hypixel.net/Booster_Cookie"
      }
    }],

    "bazaar_flipper": [{
      "text": "Bazaar Flipper",
      "color": "gold",
      "hover_event": {
        "action": "show_text",
        "value": [
          { "text": "Bazaar Flipper\n", "color": "gold", "bold": true },
          { "text": "An Account Upgrade that reduces tax\nand increases your active order limit.\n\n", "color": "gray" },
          { "text": "↗ Click to open wiki", "color": "dark_gray", "italic": true }
        ]
      },
      "click_event": {
        "action": "open_url",
        "url": "https://wiki.hypixel.net/Bazaar_Flipper"
      }
    }],

    "elizabeth": [{
      "text": "Elizabeth",
      "color": "light_purple",
      "hover_event": {
        "action": "show_text",
        "value": [
          { "text": "Elizabeth\n", "color": "light_purple", "bold": true },
          { "text": "NPC at the ", "color": "gray" },
          { "text": "Community Center", "color": "gray" },
          { "text": " in the SkyBlock Hub.\n", "color": "gray" },
          { "text": "Sells Account Upgrades using Gems.\n\n", "color": "gray" },
          { "text": "↗ Click to open wiki", "color": "dark_gray", "italic": true }
        ]
      },
      "click_event": {
        "action": "open_url",
        "url": "https://wiki.hypixel.net/Elizabeth"
      }
    }],

    "community_center": [{ "text": "Community Center", "color": "aqua" }],
    "skyblock_hub": [{ "text": "SkyBlock Hub", "color": "aqua" }]
  },

  "mod.bazaarutils": "Bazaar Utils",
  "key.category.minecraft.bazaarutils": "Bazaar Utils",

  "bazaarutils.hypixel.account_upgrades.bazaar_flipper.{}": {
    "not_upgraded.label": "Not Upgraded",
    "first_tier.label": "Bazaar Flipper I",
    "second_tier.label": "Bazaar Flipper II"
  },

  "bazaarutils.config.{}": {

    "separator.introductory.label": "Welcome to Bazaar Utils!",
    "separator.introductory.hint": "Thank you for installing Bazaar Utils! This mod provides quality of life features for the Hypixel Bazaar.",

    "bazaar_flipper_account_upgrade.{}": {
      "label": "Bazaar Flipper Account Upgrade",
      "hint": [
        "The tier of your ", { "translate": "bazaarutils.ref.bazaar_flipper" },
        " Account Upgrade, which is factored in on tax calculation and current order limits.",
        "\nYour Bazaar Flipper level can be upgraded by talking to ",
        { "translate": "bazaarutils.ref.elizabeth" }, " at the ",
        { "translate": "bazaarutils.ref.community_center" }, " in the ",
        { "translate": "bazaarutils.ref.skyblock_hub" }, "."
      ]
    },

    "chat.{}": {
      "category.label": "Chat",
      "category.hint": "Configurations for the chat features of the mod",

      "separator.useless_bazaar_notifications_remover.label": "Useless Bazaar Notifications",
      "useless_bazaar_notifications_remover.{}": {
        "label": "Useless Bazaar Notifications",
        "hint": "Removes specific transient messages sent to chat when interacting with the Bazaar to reduce clutter.",
        "excluded_notifications.{}": {
          "label": "Excluded Notifications",
          "hint": "A list of messages and notifications to block from chat."
        }
      },

      "separator.stash_messages_remover.label": "Stash Messages",
      "stash_messages_remover.{}": {
        "label": "Stash Messages",
        "hint": "Removes chat messages reminding you to pick up items from your stash."
      }
    },

    "buttons.{}": {
      "category.label": "Buttons",
      "category.hint": "Configurations for the buttons to be injected/handled by the mod",

      "separator.mod_buttons.{}": {
        "label": "Mod Buttons",
        "hint": "Adds buttons to inventory screens for quick access to mod features."
      },

      "open_settings.{}": {
        "label": "Mod Settings Button",
        "hint": "Adds a button to selected menus for quick access to the mod's settings."
      },

      "open_orders.{}": {
        "label": "Orders Page Button",
        "hint": [
          "Adds a button to selected menus for quick access to your orders page.",
          "\n\nRequires an active ", { "translate": "bazaarutils.ref.booster_cookie" }, "."
        ]
      },

      "separator.container_buttons.{}": {
        "label": "Container Buttons",
        "hint": "Adds helper buttons to specific container interfaces."
      },

      "cancel_order_and_search.{}": {
        "label": "Cancel & Search Button",
        "hint": "Adds a button to unfilled order/offer pages to cancel the order and immediately search for the item again."
      },

      "button.{}": {
        "widget.{}": {
          "enabled.{}": {
            "label": "Enabled",
            "hint": "Whether the button will be enabled."
          },
          "size.label": "Button Size",
          "spacing.label": "Spacing"
        },
        "container.{}": {
          "enabled.{}": {
            "label": "Enabled",
            "hint": "Whether the button will be enabled."
          },
          "slot_number.{}": {
            "label": "Slot Number",
            "hint": "The container slot where the button will be placed."
          }
        }
      },

      "bookmarks.{}": {
        "category.label": "Bookmarks",

        "separator.introductory.{}": {
          "label": "Item Bookmarks",
          "hint": "Item Bookmarks allow you to quickly search for specific items on the Bazaar."
        },

        "open_bookmark.{}": {
          "label": "Open Bookmark",
          "hint": "Configures the button on selected menus that quickly searches for the bookmarked item."
        },

        "toggle_bookmark.{}": {
          "label": "Bookmark Item",
          "hint": "Adds a button to item pages to toggle whether the item is bookmarked for quick access."
        },

        "reset_bookmarks.label": "Saved Bookmarks",
        "reset_bookmarks.runnable": "Reset"
      }
    },

    "inventory.{}": {
      "category.label": "Inventory",
      "category.hint": "Configurations for the inventory features of the mod",

      "separator.instant_sell_restrictions.label": "Instant Sell Restrictions",
      "instant_sell_restrictions.{}": {
        "label": "Instant Sell Restrictions",
        "hint": [
          "Locks the Bazaar's Instant Sell button based on inventory or action criteria to prevent accidental sales."
        ],

        "clicks_required.{}": {
          "label": "Clicks Required",
          "hint": [
            "The number of clicks required on the Instant Sell button to confirm the action."
          ]
        },

        "rules.{}": {
          "category.label": "Instant Sell Rules",
          "category.hint": "Manage the rules to be checked by the Instant Sell Restrictions feature",

          "separator.numeric_restrictions.{}": {
            "label": "Number predicates/restrictions",
            "hint": [
              "Rules checking numeric conditions (e.g., total items or coins) to restrict Instant Sell."
            ]
          },

          "numeric_restriction.{}.label": [
            "#1 Number Predicate",
            "#2 Number Predicate",
            "#3 Number Predicate",
            "#4 Number Predicate",
            "#5 Number Predicate"
          ],

          "separator.string_restrictions.{}": {
            "label": "String predicates/restrictions",
            "hint": [
              "Rules checking specific item names or types to restrict Instant Sell."
            ]
          },

          "string_restriction.{}.label": [
            "#1 Name Predicate",
            "#2 Name Predicate",
            "#3 Name Predicate",
            "#4 Name Predicate",
            "#5 Name Predicate"
          ],

          "restriction.{}": {
            "enabled.label": "Enabled",
            "numeric.{}": {
              "label": "Restriction Type",
              "hint": "Determines if the restriction applies to total coin value or item quantity."
            },
            "amount.{}": {
              "label": "Amount",
              "hint": "The quantity of coins or items required to trigger the lock."
            },
            "name.{}": {
              "label": "Item Name",
              "hint": "The name of the item that, if present, will lock Instant Sell."
            }
          }
        }
      },

      "separator.instant_sell_highlight.label": "Instant Sell Highlight",
      "instant_sell_highlight.{}": {
        "label": "Instant Sell Highlight",
        "hint": [
          "Highlights items in your inventory that would be sold by the Instant Sell button."
        ],
        "color.label": "Highlight Color"
      },

      "separator.order_status_highlight.label": "Order Status Highlight",
      "order_status_highlight.{}": {
        "label": "Order Status Highlight",
        "hint": "Highlights the status of your Bazaar Orders by coloring the items with representative colors.",
        "competitive_color.{}": {
          "label": "Competitive Color",
          "hint": "The highlight color for orders that are currently the best market offer."
        },
        "matched_color.{}": {
          "label": "Matched Color",
          "hint": "The highlight color for orders that match the current market price."
        },
        "outbid_color.{}": {
          "label": "Outbid Color",
          "hint": "The highlight color for orders that have been outbid."
        }
      }
    },

    "overlays.{}": {
      "category.label": "Overlays",
      "category.hint": "Configurations for the overlays created by the mod",

      "separator.price_charts.label": "Price Charts",
      "price_charts.{}": {
        "label": "Price Charts",
        "hint": "Adds a link to Bazaar item tooltips for quick access to market price charts.",
        "show_outside_bazaar.{}": {
          "label": "Show Outside of Bazaar",
          "hint": "Whether to show price charts in tooltips when outside of a Bazaar menu."
        }
      },

      "separator.bazaar_limits_visualizer.label": "Bazaar Limits",
      "bazaar_limits_visualizer.{}": {
        "label": "Bazaar Limits",
        "hint": [
          "Displays your daily Bazaar Limit status on Bazaar screens.\n\nProfiles are limited to ",
          {
            "text": "15,000,000,000.00 coins",
            "color": "gold",
            "hover_event": {
              "action": "show_text",
              "value": [
                { "text": "Daily Bazaar Limit\n", "color": "gold", "bold": true },
                { "text": "Resets at midnight UTC.\n", "color": "gray" },
                { "text": "Applies per-profile, not per-account.", "color": "dark_gray", "italic": true }
              ]
            }
          },
          " in tradeable orders/offers per day."
        ],
        "reset_limits.label": "Daily Order Limits",
        "reset_limits.runnable": "Reset"
      }
    },

    "notifications.{}": {
      "category.label": "Notifications",
      "category.hint": "Configurations for the notifications pushed by the mod",

      "separator.order_notifications.label": "Order Notifications",
      "order_notifications.{}": {
        "label": "Order Notifications",
        "hint": "Enables notifications related to the status of your Bazaar orders.",
        "outbid.{}": {
          "label": "Order Outbidded",
          "hint": "Configures the notification shown when your order is outbid."
        },
        "filled.{}": {
          "label": "Order Filled",
          "hint": "Configures the notification shown when your order is filled."
        }
      },

      "notification.{}": {
        "enabled.{}": {
          "label": "Enabled",
          "hint": "Whether the notification will be produced."
        },
        "auto_open_bazaar.label": "Auto Open Bazaar",
        "emit_chat_message.label": "Emit Chat Message",
        "emit_client_sound.label": "Emit Client Sound"
      }
    },

    "developer.{}": {
      "category.label": "Developer Config",
      "category.hint": "Developer configurations & toggleable tools of the mod",
      "enabled.{}": {
        "label": "Enabled",
        "hint": "Global toggle for all developer features and utilities."
      },
      "disable_error_notifications.label": "Disable Error Notifications",
      "debug_messages.{}": {
        "label": "Debug Messages",
        "hint": "Configures debug messages sent to chat regarding mod routines and state"
      }
    }
  }
}
